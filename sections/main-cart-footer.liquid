{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #main-cart-footer .page-width{
    padding: 0;
  }
  /* 间距控制 */
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* 底部容器整体样式 */
  .cart__footer {
  background: rgba(var(--color-background), 1);
  border-radius: 12px;
  padding: 24px;
  border: 1px solid rgba(var(--color-foreground), 0.06);
  }

  /* 备注模块 */
  .cart__note {
  margin-bottom: 20px;
  }
  .cart__note label {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 8px;
  display: block;
  }
  .cart__note .text-area {
  width: 100%;
  min-height: 88px;
  padding: 12px 14px;
  border: 1px solid rgba(var(--color-foreground), 0.12);
  border-radius: 8px;
  background: #fafafa;
  font-size: 14px;
  transition: all 0.2s ease;
  }
  .cart__note .text-area:focus {
  outline: none;
  background: #ffffff;
  border-color: rgba(var(--color-foreground), 0.25);
  }

  /* 折扣样式 */
  .discounts__discount {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  background: #FFF5F5;
  color: #E53935;
  border-radius: 6px;
  font-size: 13px;
  margin-bottom: 6px;
  }
  .discounts__discount svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  }

  /* 小计 / 总价 */
  .totals {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-top: 1px solid rgba(var(--color-foreground), 0.06);
  border-bottom: 1px solid rgba(var(--color-foreground), 0.06);
  margin: 16px 0;
  }
  .totals__total {
  font-size: 16px;
  font-weight: 500;
  margin: 0;
  }
  .totals__total-value {
  font-size: 22px;
  font-weight: 700;
  margin: 0;
  }

  /* 税务提示 */
  .tax-note {
  font-size: 12px;
  color: rgba(var(--color-foreground), 0.5);
  line-height: 1.5;
  margin-bottom: 20px;
  }

  /* 结算按钮 */
  #checkout {
  width: 100%;
  height: 48px;
  background: #000;
  color: #fff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.25s ease;
  font-family: var(--self_font);
  }
  #checkout:hover:not(:disabled) {
  opacity: 0.9;
  transform: translateY(-1px);
  }
  #checkout:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  }

  /* 额外支付按钮 */
  .cart__dynamic-checkout-buttons {
  margin-top: 12px;
  }

  /* 错误提示 */
  #cart-errors {
  margin-top: 10px;
  color: #E53935;
  font-size: 13px;
  }

  /* 布局间距 */
  .cart__blocks {
  display: flex;
  flex-direction: column;
  gap: 16px;
  }

  /* 桌面端 */
  @media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .cart__footer {
  padding: 32px;
  }
  .totals__total-value {
  font-size: 26px;
  }
  #checkout {
  height: 52px;
  font-size: 16px;
  }
  }
{%- endstyle -%}

<!-- 以下完全保持你原来的 HTML/Liquid 结构 100% 不变 -->
<div
        style="font-family:var(--self_font);padding: 0 2rem;background-color:transparent;"
        class="color-{{ section.settings.color_scheme }}{% if cart == empty %} is-empty{% endif %}"
        id="main-cart-footer"
        data-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="cart__footer isolate section-{{ section.id }}-padding">
      {%- if settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
                  class="text-area field__input"
                  name="note"
                  form="cart"
                  id="Cart-note"
                  placeholder="{{ 'sections.cart.note' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}

      <div class="cart__blocks">
        <div class="js-contents" {{ block.shopify_attributes }}>
          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--position">
                    {%- render 'icon-discount' -%}
                    {{ discount.title }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <div class="totals">
            <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
            <p class="totals__total-value">{{ cart.total_price | money_with_currency }}</p>
          </div>

          <small class="tax-note caption-large rte">
            {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
            {%- elsif cart.taxes_included -%}
              {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
            {%- elsif shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
            {%- else -%}
              {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
            {%- endif -%}
          </small>
        </div>
        <div class="cart__ctas" {{ block.shopify_attributes }}>
          <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
          >
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>

        {%- if additional_checkout_buttons -%}
          <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
            {{ content_for_additional_checkout_buttons }}
          </div>
        {%- endif -%}
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
