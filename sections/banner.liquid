{% style %}
  .banner-container{
  width: 100%;
  padding: 0 .5rem;
  }
  .banner-con-imgs{
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  width: 100%;
  overflow: hidden;
  }
  .banner-item-img{
  height: 100%;
  }
  .banner-items{
  position: relative;
  width: 100%;
  height: fit-content;
  }
  .banner-con-imgs img{
  width: 100vw;
  height: 100%;
  max-height: 500px;
  object-fit: cover;
  object-position: center;
  }

  .banner-card{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 1.2rem 1.5rem;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 1rem;
  background: var(--gradient-background);
  max-width: 90%;
  width: auto;
  min-width: 280px;
  gap: 0.8rem;
  }

  .banner__heading {
  font-family: var(--self_font), serif;
  font-size: calc(var(--font-scale) * 1.6rem);
  margin: 0;
  line-height: 1.2;
  white-space: normal;
  word-wrap: break-word;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  }

  .banner__subheading{
  width: 20rem;
  padding: 0;
  margin: 0;
  font-size: 1.1rem;
  color: var(--white-color);
  font-weight: 700;
  line-height: 1.4;
  white-space: normal;
  word-break: break-word;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  text-shadow: 0 1px 3px rgba(0,0,0,0.35);
  }

  .banner__buttons {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 0.5rem;
  }

  .banner__buttons .button{
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: 0 2.2rem;
  height: 3rem;
  color: var(--white-color);
  border-radius: 999px;
  border: 2px solid var(--white-color);
  text-shadow: 0 1px 2px rgba(0,0,0,0.25);
  box-shadow: 0 2px 5px rgba(0,0,0,0.25);
  background: var(--gradient-background);
  white-space: nowrap;
  }

  .animate--ambient img{
  animation: animationAmbient 30s linear infinite;
  }
  .banner-controller{
  padding: 1rem;
  }
  .banner-con-controller{
  display: flex;
  justify-content: center;
  align-items: center;
  }
  .banner-btn{
  display: flex;
  justify-content: center;
  align-items: center;
  width: 3rem;
  height: 3rem;
  }
  .banner-btn .icon{
  width: 1.2rem;
  height: 1.2rem;
  }
  .btn-previous .icon,.collection-btn-previous .icon{
  transform: rotate(90deg) scale(.6);
  }
  .btn-next .icon,.collection-btn-next .icon{
  transform: rotate(-90deg) scale(.6);
  }
  .btn-previous .icon:hover,.collection-btn-previous .icon:hover{
  transform: rotate(90deg) scale(.8);
  }
  .btn-next .icon:hover,.collection-btn-next .icon:hover{
  transform: rotate(-90deg) scale(.8);
  }
  .banner-con-counter{
  font-size: .8rem;
  }
  /* dots and number style */
  .dot.dot-active{
  width: .8rem;
  height: .8rem;
  background: var(--sf-purple-color);
  }
  .number-active{
  transition: transform .2s ease-in-out;
  transform: scale(1.1);
  }
  .number-active::after{
  display: block;
  content: "";
  border: 1px solid var(--black-color);
  }
  .banner-con-dots,.banner-con-number{
  display: flex;
  justify-content: center;
  align-items: center;
  }
  .btn-dot,.btn-number{
  display: flex;
  justify-content: center;
  align-items: center;
  width: 2rem;
  height: 2rem;
  }
  .dot{
  width: .6rem;
  height: .6rem;
  border: 1px solid var(--black-color);
  border-radius: 50%;
  }
  .dot:not(span[class= 'dot dot-active']):hover,
  .number-span:not(span[class='number-span number-active']):hover{
  transform: scale(1.5);
  }

  @keyframes animationAmbient{
  0%{
  transform: rotate(0) translate(1em) rotate(0) scale(1.2);
  }
  100%{
  transform: rotate(360deg) translate(1em) rotate(-360deg) scale(1.2);
  }
  }
  @media screen and (max-width: 750px){
  .banner-container{
  padding: 1rem;
  }
  .banner-items{
  height: fit-content;
  }
  .banner-item-img{
  margin: 0 auto;
  width:96%;
  overflow: hidden;
  height: auto;
  border-radius: 1rem;

  }
  .banner-con-imgs img{
  height: 16rem;
  }
  .banner-card{
  position: static;
  transform: none;
  background: transparent;
  max-width: 100%;
  width: 100%;
  padding: 1rem;
  gap: 0.6rem;
  }
  .banner__heading{
  font-size: calc(var(--font-scale) * 1.4rem);
  -webkit-line-clamp: 2;
  }
  .banner__subheading {
  font-size: 1.2rem;
  -webkit-line-clamp: 3;
  }
  }
{% endstyle %}

<banner-control>
  <div class='banner-container banner-{{ section.id }}'>
    <div class='banner-con-imgs animate--{{ section.settings.image_behavior }}'
         data-auto_play={{ section.settings.auto_play }}
         data-speed={{ section.settings.speed }}
         data-controller-type={{ section.settings.banner_controller_type }}
    >
      {% for block in section.blocks %}
        <div class='banner-item-box-{{ forloop.index }} banner-items' style='z-index: calc({{ section.blocks.size }} - {{ forloop.index }})'>
          <div class='banner-item-img'>
            {%- if block.settings.image -%}
              {%- liquid
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                assign image_format = 'webp'
                if section.settings.image_behavior == 'ambient'
                  assign sizes = '(max-width: 750px) 100vw, 120vw'
                  assign widths = '375, 550, 750, 900, 1100, 1320, 1500'
                else
                  assign sizes = '(max-width: 750px) 100vw, (max-width: 1100px) 90vw, 100vw'
                  assign widths = '375, 550, 750, 900, 1100, 1500'
                endif
                assign fetch_priority = 'auto'
                if section.index == 1
                  assign fetch_priority = 'high'
                endif
              -%}
              {%- if forloop.first %}
                {{
                block.settings.image
                | image_url: width: 1200
                | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority,loading: 'eager',quantity:80,format: image_format
                }}
              {%- else -%}
                {{
                block.settings.image
                | image_url: width: 1200
                | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths,format: image_format, fetchpriority: fetch_priority,quantity:70
                }}
              {%- endif -%}
            {% else %}
              <img
                      src="{{ 'banner_default_1.webp' | asset_url }}?width=480&quality=80"
                      srcset="
                        {{ 'banner_default_1.webp' | asset_url }}?width=360&quality=80 360w,
                        {{ 'banner_default_1.webp' | asset_url }}?width=480&quality=80 480w
                      "
                      sizes="(max-width:750px) 100vw, 480px"
                      width="750"
                      height="300"
                      fetchpriority="high"
                      alt="banner image"/>
            {%- endif -%}
          </div>
          <div class='banner-card'>
            {%- if block.settings.heading != blank -%}
              <multi-lang data-target-class="banner__heading" data-lang="{{ request.locale.iso_code }}" data-json="{{ block.settings.heading | escape }}">
                <h2 class="banner__heading inline-richtext {{ block.settings.heading_size }}"></h2>
              </multi-lang>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="banner__text rte" {{ block.shopify_attributes }}>
                <multi-lang data-target-class="banner__subheading" data-lang="{{ request.locale.iso_code }}" data-json="{{ block.settings.subheading | escape }}">
                  <p class="banner__subheading"></p>
                </multi-lang>
              </div>

            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="banner__buttons">
                <a
                        {% if block.settings.link %}
                          href="{{ block.settings.link }}"
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                        class="button {% if block.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}"
                >
                  <multi-lang data-target-class="banner__button-text" data-lang="{{ request.locale.iso_code }}" data-json="{{ block.settings.button_label | escape }}">
                    <span class="banner__button-text"></span>
                  </multi-lang>
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.blocks.size > 1 %}
      <div class='banner-controller'>
        <div class='banner-con-controller'>
          <button class='banner-btn btn-previous'>
            {% render 'icon-button-previous-next' %}
          </button>
          <div class="banner-controller-type-box">
            {% if section.settings.banner_controller_type =='dots' %}
              <div class='banner-con-dots'>
                {% for block in section.blocks %}
                  <button class='btn-dot' data-index={{ forloop.index }} >
                    <span class='dot {% if forloop.first %}{{ 'dot-active' }}{% endif %}' data-index={{ forloop.index }} ></span>
                  </button>
                {% endfor %}
              </div>
            {% elsif section.settings.banner_controller_type =='counter' %}
              <div class='banner-con-counter'>
                <span class='current-page'>1</span>
                <span class='charactor'>/</span>
                <span class='total-page'>{{ section.blocks.size }}</span>
              </div>
            {% elsif  section.settings.banner_controller_type =='number' %}
              <div class='banner-con-number'>
                {% for block in section.blocks %}
                  <button class='btn-number' data-index={{ forloop.index }} >
                    <span class='number-span {% if forloop.first %}{{ 'number-active' }}{% endif %}' data-index={{ forloop.index }} >{{ forloop.index }}</span>
                  </button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          <button class='banner-btn btn-next'>
            {% render 'icon-button-previous-next' %}
          </button>
        </div>
      </div>
    {% endif %}
  </div>
</banner-control>

{% if section.blocks.size > 1 %}
  <script src={{ 'banner-control.js' | asset_url }} defer></script>
{% endif %}
{% schema %}
{
  "name":"t:sections.banner.name",
  "settings": [
    {
      "type": "select",
      "id": "image_behavior",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.animation.image_behavior.options__1.label"
        },
        {
          "value": "ambient",
          "label": "t:sections.all.animation.image_behavior.options__2.label"
        }
      ],
      "default": "none",
      "label": "t:sections.all.animation.image_behavior.label"
    },
    {
      "type": "select",
      "id":"banner_controller_type",
      "options": [
        {
          "value": "dots",
          "label": "t:sections.banner.settings.banner_controller_type.options__1.label"
        },
        {
          "value": "counter",
          "label": "t:sections.banner.settings.banner_controller_type.options__2.label"
        },
        {
          "value": "number",
          "label": "t:sections.banner.settings.banner_controller_type.options__3.label"
        }
      ],
      "default":"dots",
      "label": "t:sections.banner.settings.banner_controller_type.label"
    },
    {
      "type": "checkbox",
      "id": "auto_play",
      "default": true,
      "label": "t:sections.banner.settings.auto_play.label"
    },
    {
      "type": "range",
      "id": "speed",
      "min":3,
      "max": 9,
      "default":5,
      "unit":"s",
      "label": "t:sections.banner.settings.speed.label",
      "info": "t:sections.banner.settings.speed.info"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name":"t:sections.banner.blocks.slide.name",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.banner.blocks.slide.settings.image.label"
        },
        {
          "type": "textarea",
          "id": "heading",
          "default": "{ 'en': 'Image slide','zh-CN': '轮播图标题' }",
          "label": "t:sections.banner.blocks.slide.settings.heading.label",
          "info": "t:sections.banner.blocks.slide.settings.heading.info"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "default": "{ 'en': 'Tell your brand's story through images','zh-CN': '通过图片展示您的品牌故事' }",
          "label": "t:sections.banner.blocks.slide.settings.subheading.label",
          "info": "t:sections.banner.blocks.slide.settings.subheading.info"
        },
        {
          "type": "textarea",
          "id": "button_label",
          "default": "{ 'en': 'Button Label','zh-CN': '按钮标签' }",
          "label": "t:sections.banner.blocks.slide.settings.button_label.label",
          "info": "t:sections.banner.blocks.slide.settings.button_label.info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.banner.blocks.slide.settings.link.label"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.banner.presets.banner.name",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}

{% endschema %}
