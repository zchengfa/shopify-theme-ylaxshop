{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* 全局重置与基础布局 */
  cart-items {
  font-family: var(--self_font), serif;
  padding: 2rem;
  background-color: transparent;
  }

  .page-width {
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  }

  /* 标题区域 */
  .title-wrapper-with-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(var(--color-border), 0.2);
  }

  .title.title--primary {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 700;
  margin: 0;
  }

  .underlined-link {
  text-decoration: underline;
  color: rgba(var(--color-foreground), 0.7);
  transition: color 0.2s ease;
  }

  .underlined-link:hover {
  color: rgb(var(--color-foreground));
  }

  /* 空购物车样式 */
  .cart__warnings {
  text-align: center;
  padding: 6rem 2rem;
  }

  .cart__empty-text {
  font-size: 1.5rem;
  margin-bottom: 2rem;
  color: rgba(var(--color-foreground), 0.7);
  }

  .continue-shopping-btn {
  padding: 1rem 2.5rem;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  border-radius: 999px;
  transition: all 0.3s ease;
  font-size: 1.1rem;
  border: none;
  cursor: pointer;
  display: inline-block;
  }

  .continue-shopping-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  background: rgb(var(--color-button-hover));
  }

  /* 数量选择器 优化 */
  .cart-quantity{
  display: flex;
  align-items: center;
  border-radius: 10px;
  overflow: hidden;
  background: #f7f7f7;
  border: 1px solid #eee;
  }

  .quantity__button{
  width: 3rem;
  height: 3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 1.2rem;
  }

  .quantity__button:hover {
  background: #ececec;
  }

  .quantity__input{
  width: 3.2rem;
  height: 3rem;
  border: none;
  text-align: center;
  font-size: 1rem;
  font-weight: 600;
  background: transparent;
  }

  /* 移除按钮 */
  cart-remove-button .button {
  width: 2.5rem;
  height: 2.5rem;
  min-height: 2.5rem;
  color: rgb(var(--color-foreground));
  background: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s ease;
  }

  cart-remove-button .button:hover {
  color: #e53935;
  }

  /* 商品卡片 */
  .cart-item {
  display: grid;
  grid-template-columns: 120px 1fr auto;
  gap: 1.5rem;
  align-items: center;
  padding: 1.5rem;
  background: rgb(var(--color-background));
  border-radius: 12px;
  margin-bottom: 1rem;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .cart-item__media {
  grid-column: 1;
  grid-row: 1;
  }

  .cart-item__image-container {
  border-radius: 8px;
  overflow: hidden;
  }

  .cart-item__image {
  width: 100%;
  height: auto;
  object-fit: cover;
  }

  .cart-item__details {
  grid-column: 2;
  grid-row: 1;
  }

  .cart-item__name {
  font-size: 1.1rem;
  font-weight: 600;
  margin: 0.5rem 0;
  color: rgb(var(--color-foreground));
  -webkit-line-clamp: 2;
  }

  .product-option {
  font-size: 0.9rem;
  color: rgba(var(--color-foreground), 0.7);
  margin: 0.3rem 0;
  }

  .cart-item__totals.right {
  grid-column: 3;
  grid-row: 1;
  font-weight: 600;
  }

  .cart-item__quantity {
  grid-column: 2 / 4;
  grid-row: 2;
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-top: 1rem;
  }

  /* 响应式 - 移动端 */
  @media screen and (max-width: 749px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .cart-item {
  grid-template-columns: 100px 1fr;
  gap: 1rem;
  padding: 1.2rem;
  }

  .cart-item__media {
  grid-column: 1;
  }

  .cart-item__details {
  grid-column: 2;
  }

  .cart-item__totals.right {
     display: none;
  }

  .cart-item__quantity {
  grid-column: 1 / 3;
  justify-content: space-between;
  }
  }

  /* 浏览器样式重置 */
  input::-webkit-outer-spin-button,
  input::-webkit-inner-spin-button {
  -webkit-appearance:none;
  margin: 0;
  }

  input[type="number"]{
  -moz-appearance:textfield;
  }

  .visually-hidden{
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border-width: 0;
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<cart-items
        id="main-cart-items"
        data-id="{{ section.id }}"
        class="color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}"
>
  <div class="page-width js-contents">
    {%- if cart != empty -%}
      <div class="title-wrapper-with-link">
        <h1 class="title title--primary">{{ 'sections.cart.title' | t }}</h1>
        <a href="{{ routes.all_products_collection_url }}" class="underlined-link">
          {{ 'general.continue_shopping' | t }}
        </a>
      </div>

      <form action="{{ routes.cart_url }}" method="post" id="cart" class="cart">
        <div class="cart__items">
          {% for item in cart.items %}
            <div class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
              <div class="cart-item__media">
                {% if item.image %}
                  <div class="cart-item__image-container">
                    <img
                            src="{{ item.image | image_url: width: 150, height: 150 }}"
                            srcset="{{ item.image | image_url: width: 150 }} 150w, {{ item.image | image_url: width: 300 }} 300w"
                            sizes="(min-width: 750px) 150px, 100px"
                            class="cart-item__image"
                            alt="{{ item.image.alt | default: item.title | escape }}"
                            loading="lazy"
                            width="{{ item.image.width | default: 150 }}"
                            height="{{ item.image.height | default: 150 }}"
                    >
                  </div>
                {% endif %}
              </div>

              <div class="cart-item__details">
                {%- if settings.show_vendor -%}
                  <p class="product-option">{{ item.product.vendor }}</p>
                {%- endif -%}

                <a href="{{ item.url }}" class="cart-item__name text-ellipsis-multiline">{{ item.product.title | escape }}</a>

                {%- if item.original_price != item.final_price -%}
                  <div class="cart-item__discounted-prices">
                    <s class="product-option">{{ item.original_price | money_with_currency }}</s>
                    <strong class="cart-item__final-price">{{ item.final_price | money_with_currency }}</strong>
                  </div>
                {%- else -%}
                  <p class="product-option">{{ item.original_price | money_with_currency }}</p>
                {%- endif -%}

                {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                  <div class="product-options">
                    {%- for option in item.options_with_values -%}
                      {% unless option.name == 'Title' %}
                        <div class="product-option">
                          <p class="text-ellipsis-multiline">{{ option.value }}</p>
                        </div>
                      {%endunless%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- for discount in item.line_level_discount_allocations -%}
                  <div class="product-option discount">
                    {% render 'icon-discount' %}
                    {{ discount.discount_application.title }}
                  </div>
                {%- endfor -%}
              </div>

              <div class="cart-item__totals right">
                {{ item.final_line_price | money_with_currency }}
              </div>

              <div class="cart-item__quantity">
                <quantity-input class="quantity cart-quantity" data-loading-parent="CartItem-{{ item.index | plus: 1 }}">
                  <button class="quantity__button" name="minus" type="button">
                    <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t }}</span>
                    {% render 'icon-minus' %}
                  </button>
                  <input
                          class="quantity__input"
                          type="number"
                          name="updates[]"
                          data-quantity-variant-id="{{ item.variant_id }}"
                          value="{{ item.quantity }}"
                          min="1"
                          aria-label="{{ 'products.product.quantity.label' | t }}"
                          id="Quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                  >
                  <button class="quantity__button" name="plus" type="button">
                    <span class="visually-hidden">{{ 'products.product.quantity.increase' | t }}</span>
                    {% render 'icon-plus' %}
                  </button>
                </quantity-input>

                <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                  <a
                          href="{{ item.url_to_remove }}"
                          class="button"
                          aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                  >
                    {% render 'icon-remove' %}
                  </a>
                </cart-remove-button>
              </div>
            </div>
          {% endfor %}
        </div>
      </form>
    {%- else -%}
      <div class="cart__warnings">
        <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
        <a href="{{ routes.all_products_collection_url }}" class="continue-shopping-btn">
          {{ 'general.continue_shopping' | t }}
        </a>
        {%- if shop.customer_accounts_enabled and customer == null -%}
          <p class="cart__login-paragraph">
            {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</cart-items>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
