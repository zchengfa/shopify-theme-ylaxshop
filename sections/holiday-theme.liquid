{% style %}
.holiday-theme-container{
    width: 92%;
    margin: 0 auto;
    padding: 1rem;
    position: relative;
}

.holiday-product-box{
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    background: {{ section.settings.holiday_background }};
    border-radius: 1.5rem;
    padding: 1.5rem;
    box-shadow: 0 8px 32px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.18), 0 2px 8px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.12);
}

/* 平板设备 - 3列 */
@media (max-width: 1024px) {
    .holiday-product-box {
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
        padding: 1.2rem;
    }
}

/* 小平板设备 - 2列 */
@media (max-width: 768px) {
    .holiday-product-box {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        padding: 1rem;
    }
}

/* 手机设备 - 1列 */
@media (max-width: 480px) {
    .custom-card-popover,.count-down-box{
        margin: 0 auto;
    }
    .holiday-product-box {
        grid-template-columns: 1fr;
        gap: 0.8rem;
        padding: 0.8rem;
    }
}

.holiday-product-item{
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 1rem;
    width: 100%;
    max-width: 400px;
    border-radius: 1rem;
    background: radial-gradient(circle at center, rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.25) 0%, rgba(255, 255, 255, 0.96) 100%);
    border: 0.12rem solid rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.25);
    box-shadow: 0 4px 12px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.15);
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

.holiday-product-item:hover {
    transform: translateY(-0.15rem);
    border-color: rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.45);
    box-shadow: 0 8px 20px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.25);
}

.holiday-theme-img{
    width: 100%;
    border-radius: 1rem;
    box-shadow: 0 4px 16px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.18);
}

.holiday-product-img-box{
    width: fit-content;
    height: 100px;
    overflow: hidden;
    border-radius: .8rem;
    box-shadow: 0 2px 8px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.12);
}

.holiday-img{
    width: fit-content;
    height: 100px;
    transition: transform 0.3s ease;
}

.holiday-product-item:hover .holiday-img {
    transform: scale(1.05);
}

.custom-card-popover{
    border-radius: .8rem;
    margin: 1rem auto;
    box-shadow: 0 4px 12px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.15);
}

.count-down-box{
    box-shadow: 0 8px 32px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.25), 0 4px 12px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.15);
    overflow: hidden;
    border-bottom-right-radius: 3rem;
    background: radial-gradient(circle at center, rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.25) 0%, rgba(255, 255, 255, 0.96) 100%);
    border: 0.15rem solid rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.35);
    transition: all 0.3s ease;
    gap: 0.5rem;
}

.count-down-box:hover {
    box-shadow: 0 12px 40px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.3), 0 6px 16px rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.2);
    border-color: rgba({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}}, 0.45);
}

.custom-card-popover, .count-down-box{
    width: 25%;
    min-width: 270px;
}

.holiday-product-params{
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    height: 100px;
    max-width: 200px;
    padding-left: 0.8rem;
    flex: 1;
}

.holiday-product-name{
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: .5rem;
}

.holiday-product-price{
    font-size: 1.05rem;
    font-weight: 700;
    color: rgb({{section.settings.holiday_background | color_to_rgb | remove: 'rgb(' | remove: ')'}});
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.15), 0 0 1px rgba(0, 0, 0, 0.1);
    mix-blend-mode: difference;
}

.holiday-product-title{
    margin-bottom: .5rem;
    max-width: 100px;
    color: rgb(var(--color-foreground));
    font-weight: 500;
}

.holiday-product-desc{
    max-width: 140px;
    font-size: .9rem;
    font-family: var(--self_font), serif;
    line-height: 1.2rem;
    -webkit-line-clamp: 2;
    color: rgba(var(--color-foreground), 0.8);
}

.holiday-product-vendor {
    font-size: .85rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 0.2rem 0;
}


@media (max-width: 450px) {
    .holiday-theme-img{
        display: none;
    }

    .holiday-product-item {
        width: 95%;
        padding: 0.8rem;
    }

}

{% endstyle %}


<div class='holiday-theme-container'>
    {% if section.settings.image  %}
        <div class='holiday-theme-img-box holiday-theme-container-item'>
            <img
  class='holiday-theme-img'
  srcset="
    {%- if section.settings.image.width >= 600 -%}{{ section.settings.image | image_url: width: 600 }} 600w,{%- endif -%}
    {%- if section.settings.image.width >= 800 -%}{{ section.settings.image | image_url: width: 800 }} 800w,{%- endif -%}
    {%- if section.settings.image.width >= 1000 -%}{{ section.settings.image | image_url: width: 1000 }} 1000w,{%- endif -%}
    {{ section.settings.image | image_url }} {{ section.settings.image.width }}w
  "
  src="{{ section.settings.image | image_url: width: 1000, height: 200 }}"
  sizes="(min-width: 1200px) 1000px, (min-width: 990px) 800px, (min-width: 750px) 600px, 100vw"
  alt="{{ section.settings.image.alt | escape }}"
  width="1000"
  height="200"
  loading="lazy"
/>
        </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
        <div class='holiday-product-box holiday-theme-container-item {% if section.blocks.size == 1 %} flex-product-start {% endif %}'>
            {% if section.settings.add_countdown_component == true %}
                <count-down class="count-down-box" data-activity_end_time={{ section.settings.countdown_end_date }}>
                    {% comment %} <div class="count-down-item"></div> {% endcomment %}
                    {% comment %} 卡片翻动效果 {% endcomment %}
                    {% render 'card-flipping-effect',
                        card_bg_color: section.settings.card_bg_color,
                        multi_text_color: section.settings.multi_text_color,
                        container_bg_color: section.settings.holiday_background
                    %}
                </count-down>
            {% endif %}
            {% for block in section.blocks %}
                {% liquid
                    assign product = block.settings.holiday_product
                %}
               <card-popover class='custom-card-popover'
                 data-title='holiday-product-title'
                 data-description='holiday-product-desc'
                 data-price='holiday-product-price'
                 data-img="holiday-img"
                 data-vendor='holiday-product-vendor'
                 data-component-popover-id='{{ shop.name }}-global-component-popover'
                 data-url='{{ product.url }}'
                 data-display-type='{{ section.settings.show_type }}'
                 data-card-popover-delay={{ section.settings.card_popover_delay }}
                >
                <a href="{{ product.url }}" class="holiday-product-item">
                    <div class='holiday-product-img-box'>
                        <img
                          class='holiday-img transition-img'
                          srcset="
                            {%- if product.featured_image.width >= 165 -%}{{ product.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
                            "
                          src="{{ product.featured_image | image_url: width: 200, height: 200 }}"
                          sizes="(min-width: 1200px) 200px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                          alt="{{ product.title | escape }}"
                          width="200"
                          height="200"
                          loading="lazy"
                        />
                    </div>
                    <div class='holiday-product-params'>
                        <div class='holiday-title-desc'>
                            <p class="holiday-product-title text-ellipsis" >{{ product.title }}</p>
                            <div class='holiday-product-desc text-ellipsis-multiline'>{{ product.description }}</div>
                        </div>
                        {% if product.vendor != empty %}
                            <span class="holiday-product-vendor gradient-text">{{  product.vendor }}</span>
                        {% endif %}
                        <span class="holiday-product-price">{{ product.price | money_with_currency }}</span>
                    </div>
                </a>
               </card-popover>
            {% endfor %}
        </div>
       {% if section.settings.show_card_popover %}
        <script src={{ 'card-popover.js' | asset_url }} defer></script>
       {% endif %}
    {% endif %}
</div>

{% schema %}
{
    "name": "t:sections.holiday_theme.name",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.holiday_theme.settings.image.label"
        },
        {
            "type": "checkbox",
            "id": "add_countdown_component",
            "default":true,
            "label": "t:sections.holiday_theme.settings.add_countdown_component.label",
            "info": "t:sections.holiday_theme.settings.add_countdown_component.info"
        },
        {
            "type": "text",
            "id": "countdown_end_date",
            "default": "2026-12-31+00:00:00",
            "label": "t:sections.holiday_theme.settings.countdown_end_date.label",
            "info": "t:sections.holiday_theme.settings.countdown_end_date.info"
        },

        {
            "type": "color_background",
            "id": "multi_text_color",
            "label": "t:sections.count_down.settings.multi_text_color.label",
            "default": "linear-gradient(45deg, #ff00a9, #fffb00, #00ff7f, #0088ff)"
        },
        {
            "type": "checkbox",
            "id": "show_card_popover",
            "default":true,
            "label": "t:sections.holiday_theme.settings.show_card_popover.label",
            "info": "t:sections.holiday_theme.settings.show_card_popover.info"
        },
        {
            "type": "range",
            "id": "card_popover_delay",
            "min": 0,
            "max": 5000,
            "step": 100,
            "default": 800,
            "unit": "ms",
            "label": "t:sections.holiday_theme.settings.card_popover_delay.label",
            "info": "t:sections.holiday_theme.settings.card_popover_delay.info"
        },
        {
            "type": "select",
            "id":"show_type",
            "default":"column",
            "label": "t:sections.holiday_theme.settings.show_type.label",
            "info": "t:sections.holiday_theme.settings.show_type.info",
            "options": [
                {
                    "label": "t:sections.holiday_theme.settings.show_type.options__1.label",
                    "value": "column"
                },
                {
                    "label": "t:sections.holiday_theme.settings.show_type.options__2.label",
                    "value": "row"
                }
            ]
        },
        {
            "type": "color_background",
            "id": "holiday_background",
            "default":"#ff93b9",
            "label": "t:sections.holiday_theme.settings.holiday_background.label",
            "info": "t:sections.holiday_theme.settings.holiday_background.info"
        }
    ],
    "blocks": [
        {
            "type": "product",
            "name":"t:sections.holiday_theme.blocks.holiday_product.name",
            "settings": [
                {
                    "type": "product",
                    "id": "holiday_product",
                    "label": "t:sections.holiday_theme.blocks.holiday_product.settings.product.label"
                }
            ]
        }
    ],
    "max_blocks": 7,
    "presets": [
        {
          "name": "t:sections.holiday_theme.presets.name"
        }
    ]
}
{% endschema %}
