{% layout 'theme' %}

{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  :root {
  --catalog-primary: {{ settings.catalog_primary | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --catalog-secondary: {{ settings.catalog_secondary | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --catalog-accent: {{ settings.catalog_accent | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --catalog-white: {{ settings.catalog_white | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --contact-orange: {{ settings.contact_orange | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --contact-orange-dark: {{ settings.contact_orange_dark | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  --contact-white: {{ settings.contact_white | color_to_rgb | remove: 'rgb(' | remove: ')' }};
  }

  .catalog-page {
  padding: 1.75rem 0 2rem;
  font-family: var(--self_font), serif;
  position: relative;
  background: radial-gradient(rgba(var(--contact-orange), 0.22), rgba(var(--contact-white), 1) 72%, rgba(var(--contact-white), 1) 100%);
  }

  .catalog-page::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -18%;
  width: 50rem;
  height: 50rem;
  max-width: 100vw;
  background: radial-gradient(circle, rgba(var(--contact-orange), 0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  overflow: hidden;
  }

  @media screen and (max-width: 749px) {
  .catalog-page::before {
  right: 0;
  width: 100vw;
  height: 100vw;
  top: -20%;
  }

  .catalog-page::after {
  left: 0;
  width: 100vw;
  height: 100vw;
  bottom: -20%;
  }
  }

  .catalog-page__wrapper {
  max-width: 140rem;
  margin: 0 auto 2.5rem;
  padding: 0 2.4rem;
  position: relative;
  z-index: 1;
  }

  .catalog-page__top-bar {
  max-width: 140rem;
  margin: 0 auto 1.5rem;
  padding: 0.8rem 2.4rem 0.8rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  position: sticky;
  top: 0;
  z-index: 100;
  background: radial-gradient(rgba(var(--contact-orange), 0.22), rgba(var(--contact-white), 1) 72%, rgba(var(--contact-white), 1) 100%);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  }

  .catalog-page__title {
  font-size: calc(var(--font-scale) * 1.7rem);
  margin: 0;
  color: rgb(var(--color-foreground));
  position: relative;
  font-weight: 600;
  }

  .catalog-page__title::after {
  content: '';
  position: absolute;
  bottom: -0.4rem;
  left: 0;
  width: 3rem;
  height: 0.15rem;
  background: linear-gradient(90deg, rgb(var(--color-button)), transparent);
  }

  .catalog-page__contact-label {
  font-size: calc(var(--font-scale) * 1.05rem);
  font-weight: 600;
  color: rgb(var(--color-foreground));
  opacity: 0.9;
  }

  .catalog-page__nav {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  justify-content: flex-end;
  }

  .catalog-page__nav-link {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.4rem 0;
  font-size: 0.95rem;
  font-weight: 600;
  text-decoration: none;
  color: rgb(var(--color-foreground));
  transition: color 0.25s ease;
  }

  .catalog-page__nav-link:hover {
  color: rgb(var(--color-button));
  }

  .catalog-page__nav-link.is-current {
  color: rgb(var(--color-button));
  }

  .catalog-page__nav-link::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -0.25rem;
  width: 0;
  height: 0.18rem;
  border-radius: 999px;
  background: rgb(var(--color-button));
  transform: translateX(-50%);
  transition: width 0.25s ease;
  }

  .catalog-page__nav-link:hover::after,
  .catalog-page__nav-link.is-current::after {
  width: 100%;
  }

  .catalog-tabs-container {
  position: relative;
  z-index: 89;
  max-width: 140rem;
  margin: 0 auto 2.2rem;
  padding: 0 2rem;
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: flex-start;
  }

  .catalog-tab {
  flex-shrink:0;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: .5rem 1rem;
  border-radius: 999px;
  text-decoration: none;
  font-size: 1rem;
  font-weight: 600;
  color: rgb(var(--color-foreground));
  background: radial-gradient(circle at center, rgba(var(--contact-orange), 0.3) 0%, rgba(var(--contact-white), 0.94) 100%);
  border: 0.12rem solid rgba(var(--contact-orange), 0.3);
  box-shadow: 0 4px 12px rgba(var(--contact-orange), 0.18);
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  }

  .catalog-tab:hover {
  transform: translateY(-0.15rem);
  border-color: rgba(var(--contact-orange), 0.55);
  box-shadow: 0 8px 16px rgba(var(--contact-orange), 0.28);
  }

  .catalog-tab.is-active {
  color: rgb(var(--contact-white));
  background: radial-gradient(circle at center, rgba(var(--contact-orange), 0.8) 0%, rgba(var(--contact-orange-dark), 1) 100%);
  border-color: rgba(var(--contact-orange-dark), 0.7);
  box-shadow: 0 8px 20px rgba(var(--contact-orange), 0.35);
  text-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .catalog-page__panel {
  max-width: 140rem;
  margin: 0 auto;
  padding: 2rem;
  border-radius: 1.2rem;
  background: rgba(var(--contact-white), 0.98);
  border: 2px solid rgba(var(--contact-orange), 0.3);
  box-shadow: 0 10px 40px rgba(var(--contact-orange), 0.2);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  position: relative;
  z-index: 1;
  }

  .catalog-page__grid {
  display: grid;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  gap: 1.4rem;
  }

  @media screen and (min-width: 750px) {
  .catalog-page__grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  }

  @media screen and (max-width: 749px) {
  .catalog-page__top-bar{
    box-shadow: 0 4px 12px rgba(var(--contact-orange), 0.18);
  }
  }

  @media screen and (min-width: 1200px) {
  .catalog-page__grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  }

  .catalog-page__card {
  background: rgba(var(--contact-white), 0.98);
  backdrop-filter: blur(15px);
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(var(--contact-orange), 0.16);
  border: 2px solid rgba(var(--contact-orange), 0.2);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  display: flex;
  flex-direction: column;
  }

  .catalog-page__card:hover {
  transform: translateY(-0.35rem);
  box-shadow: 0 14px 30px rgba(var(--contact-orange), 0.25);
  border-color: rgba(var(--contact-orange), 0.45);
  }

  .catalog-page__card-image {
  position: relative;
  padding-top: 100%;
  overflow: hidden;
  background: rgba(var(--contact-orange), 0.05);
  }

  .catalog-page__card-image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .catalog-page__card:hover .catalog-page__card-image img {
  transform: scale(1.08);
  }

  .catalog-page__card-badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  padding: 0.5rem 1.2rem;
  background: rgba(var(--catalog-accent), 1);
  color: rgb(var(--contact-white));
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 0.4rem;
  z-index: 1;
  letter-spacing: 0.05rem;
  text-transform: uppercase;
  }

  .catalog-page__card-content {
  padding: 1.2rem 1.2rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  flex: 1;
  }

  .catalog-page__card-title {
  font-size: calc(var(--font-scale) * 1.15rem);
  color: rgb(var(--color-foreground));
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  }

  .catalog-page__card-price {
  display: flex;
  font-size: calc(var(--font-scale) * 1rem);
  color: rgba(var(--contact-orange-dark), 1);
  font-weight: 700;
  margin-top: auto;
  width: 100%;
  gap: .5rem;
  flex-wrap: wrap;
  }
  .catalog-page__card-price .product-price {
    flex-shrink: 0;
  }

  .catalog-page__card-button {
  box-sizing: border-box;
  width: 100%;
  padding: 0.9rem 1rem;
  background: linear-gradient(135deg, rgba(var(--contact-orange), 1) 0%, rgba(var(--contact-orange-dark), 1) 100%);
  color: rgb(var(--contact-white));
  border: none;
  border-radius: 0.6rem;
  font-family: var(--self_font), serif;
  font-size: 1.05rem;
  font-weight: 600;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  text-transform: uppercase;
  letter-spacing: 0.1rem;
  box-shadow: 0 4px 12px rgba(var(--contact-orange), 0.5),
  0 2px 4px rgba(var(--contact-orange-dark), 0.25),
  inset 0 1px 0 rgba(255, 255, 255, 0.2);
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2),
  0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .catalog-page__card-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.6s ease;
  }

  .catalog-page__card-button:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(var(--contact-orange), 0.45),
  0 4px 8px rgba(var(--contact-orange-dark), 0.3),
  inset 0 1px 0 rgba(255, 255, 255, 0.3);
  text-shadow: 0 3px 6px rgba(0, 0, 0, 0.3),
  0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .catalog-page__card-button:active {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(var(--contact-orange), 0.38),
  0 2px 4px rgba(var(--contact-orange-dark), 0.2),
  inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .catalog-page__card-button:hover::before {
  left: 100%;
  }

  .catalog-page__empty {
  text-align: center;
  padding: 5rem 2rem;
  color: rgba(var(--color-foreground), 0.6);
  font-size: 1.1rem;
  }

  /* 类目显示更多下拉框样式 */
  .catalog-tabs-more-dropdown {
  position: absolute;
  top: 100%;
  left: 2rem;
  margin-top: 0.5rem;
  background: rgba(var(--contact-white), 0.98);
  border: 2px solid rgba(var(--contact-orange), 0.3);
  border-radius: 1rem;
  box-shadow: 0 10px 40px rgba(var(--contact-orange), 0.2);
  padding: 1.5rem;
  width: fit-content;
  display: none;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  }

  .catalog-tabs-more {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 1rem;
  }

  .catalog-tabs-more .catalog-tab {
  flex-shrink: 0;
  }

  /* 响应式宽度设置 */
  @media (max-width: 768px) {
  .catalog-tabs-more-dropdown {
  left: 50%;
  width: 85vw;
  max-width: none;
  transform: translateX(-50%);
  }
  }

  @media (min-width: 769px) {
  .catalog-tabs-more-dropdown {
  max-width: 100%;
  }
  }
{%- endstyle -%}

<div class="catalog-page">
  <div class="catalog-page__top-bar">
    <div class="catalog-page__contact-label">
      {{ page.title }}
    </div>

    <nav class="catalog-page__nav" aria-label="Page shortcuts">
      {% assign catalog_top_menu = linklists['main-menu'] %}

      {% if catalog_top_menu and catalog_top_menu.links.size > 0 %}
        {% for link in catalog_top_menu.links %}
          <a
                  href="{{ link.url }}"
                  class="catalog-page__nav-link{% if link.current %} is-current{% endif %}"
          >
            {{ link.title }}
          </a>
        {% endfor %}
      {% endif %}
    </nav>
  </div>

  {% assign query_handle = request.params.collection | default: '' %}
  {% assign selected_handle = '' %}

  {% if query_handle != blank and collections[query_handle] != blank %}
    {% assign selected_handle = query_handle %}
  {% else %}
    {% for collection in collections %}
      {% if collection.products_count > 0 %}
        {% assign selected_handle = collection.handle %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign current_collection = blank %}
  {% for collection in collections %}
    {% if collection.handle == selected_handle %}
      {% assign current_collection = collection %}
      {% break %}
    {% endif %}
  {% endfor %}

  <catalog-tabs data-sale="{{ 'templates.catalog.sale' | t }}" data-sold-out="{{ 'templates.catalog.sold_out' | t }}" data-money-currency="{{ 0 | money_with_currency }}" data-products-per-page="{{ settings.products_per_page }}">
    <div class="catalog-tabs-container">
      {% assign categories_limit = settings.categories_show_more_limit | default: 6 %}
      {% assign total_collections = 0 %}

     {% for collection in collections %}
        {% if collection.products_count > 0 %}
          {% assign total_collections = total_collections | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% assign current_count = 0 %}
      {% for collection in collections %}
        {% if collection.products_count > 0 %}
          {% assign current_count = current_count | plus: 1 %}
          {% if current_count <= categories_limit %}
            <button
                    type="button"
                    data-handle="{{ collection.handle }}"
                    class="catalog-tab{% if selected_handle == collection.handle %} is-active{% endif %}"
                    aria-label="{{ collection.title }}"
            >
              {{ collection.title }}
            </button>
          {% endif %}
        {% endif %}
      {% endfor %}

      {% if total_collections > categories_limit %}
        <button
                type="button"
                class="catalog-tab catalog-tab--more"
                aria-label="Show more categories"
        >
          {{ 'templates.catalog.show_more' | t }}
        </button>

        <div class="catalog-tabs-more-dropdown">
          <div class="catalog-tabs-more">
            {% assign current_count = 0 %}
            {% for collection in collections %}
              {% if collection.products_count > 0 %}
                {% assign current_count = current_count | plus: 1 %}
                {% if current_count > categories_limit %}
                  <button
                          type="button"
                          data-handle="{{ collection.handle }}"
                          class="catalog-tab{% if selected_handle == collection.handle %} is-active{% endif %}"
                          aria-label="{{ collection.title }}"
                  >
                    {{ collection.title }}
                  </button>
                {% endif %}
              {% endif %}
            {% endfor %}
            <button
                    type="button"
                    class="catalog-tab catalog-tab--less"
                    aria-label="Show less categories"
            >
              {{ 'templates.catalog.show_less' | t }}
            </button>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="catalog-page__wrapper">
      <div class="catalog-page__panel">
        <div class="catalog-page__grid">
          {% if current_collection != blank and current_collection.products.size > 0 %}
            {% assign products = current_collection.products %}
            {% for product in products limit:2%}
              <div class="catalog-page__card" >
                <div class="catalog-page__card-image">
                  {% if product.available == false %}
                    <span class="catalog-page__card-badge">{{ 'templates.catalog.sold_out' | t }}</span>
                  {% elsif product.compare_at_price > product.price %}
                    <span class="catalog-page__card-badge">{{ 'templates.catalog.sale' | t }}</span>
                  {% endif %}
                  {% if product.featured_image %}
                    {{
                    product.featured_image
                    | image_url: width: 400
                    | image_tag:
                    widths: '300, 400',
                    sizes: '(max-width: 749px) 100vw, (max-width: 1199px) 33vw, 25vw',
                    loading: 'lazy',
                    class: 'catalog-page__card-img',
                    alt: product.featured_image.alt | default: product.title | escape
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'catalog-page__placeholder' }}
                  {% endif %}
                </div>
                <div class="catalog-page__card-content">
                  <h3 class="catalog-page__card-title">{{ product.title }}</h3>
                  <div class="catalog-page__card-price">
                    {% if product.compare_at_price > product.price %}
                      <span class="product-price" style="text-decoration: line-through; opacity: 0.6;">
                      {{ product.compare_at_price | money_with_currency }}
                    </span>
                    {% endif %}
                    <span class="product-price">{{ product.price | money_with_currency }}</span>
                  </div>
                  <a href="{{ product.url }}" class="catalog-page__card-button">
                    {{ 'templates.catalog.view_product' | t }}
                  </a>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="catalog-page__empty">
              <p>{{ 'templates.catalog.no_products' | t }}</p>
            </div>
          {% endif %}
        </div>
      </div>
      {% assign pageLimit = settings.products_per_page | append:'.0' %}
      {% assign pageCount = products.size | divided_by: pageLimit | ceil %}
      {% if pageCount > 1 %}
        {% render 'universal-pagination',
                totalPages: pageCount,
                currentPage: 1,
                id: 'pagination'
        %}
      {% endif %}
    </div>
  </catalog-tabs>
</div>

<script defer src="{{ 'catalog.js' | asset_url }}"></script>
