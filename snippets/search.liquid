{% style %}
    /* 搜索框整体容器 */
    .search-box {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    }

    /* 搜索表单 */
    .search__form {
    position: relative;
    display: flex;
    align-items: center;
    gap:1rem;
    }

    /* 搜索输入框 */
    .search-input {
    width: 30vw;
    height: 3rem;
    border: 2px solid var(--black-color);
    border-radius: 2rem 0 0 2rem;
    outline: none;
    padding: 0 1.2rem;
    font-size: 1.1rem;
    background: #ffffff;
    transition: all 0.2s ease;
    }

    .search-input:focus {
    border-color: {{ section.settings.color_underline }};
    box-shadow: 0 0 0 2px rgba(255, 180, 200, 0.2);
    }
    .search-field{
      display: flex;
      flex: 1;
    }
    /* 搜索按钮 */
    .search-btn {
    height: 3rem;
    padding: 0 1rem;
    border-radius: 0 2rem 2rem 0;
    border: 2px solid var(--black-color);
    border-left: none;
    background: {{ section.settings.color_underline }};
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background 0.2s ease;
    }

    .search-btn:hover {
    opacity: 0.9;
    }

    /* 搜索结果弹窗（核心优化）*/
    .predictive-search-results {
    font-family: var(--self_font), serif;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: 100%;
    min-width: unset;
    max-width: 100%;
    background: #ffffff;
    border: 1px solid #f0d5e3;
    border-radius: 12px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    padding: 12px 16px;
    z-index: 999;
    overflow: hidden;
    }

    /* 标题 */
    #predictive-search-products {
    text-transform: uppercase;
    font-size: 0.9rem;
    color: {{ section.settings.color_underline }};
    font-weight: 600;
    padding: 8px 0;
    border-bottom: 1px solid #f8e3ef;
    }

    /* 结果列表 */
    .predictive-search-results ul {
    padding: 8px 0;
    max-height: 280px;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    }

    .predictive-search-results ul li {
    padding: 10px 6px;
    border-radius: 8px;
    transition: background 0.2s ease;
    }

    .predictive-search-results ul li:hover {
    background: #fff5f9;
    }

    /* 结果项布局 */
    .predictive-search-results ul a {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none !important;
    color: #222;
    }

    /* 商品图片 */
    .predictive-search-results a img {
    border-radius: 8px;
    width: 44px;
    height: 44px;
    object-fit: cover;
    }

    /* 商品文字 */
    .predictive-search-results a .predictive-search-product-text {
    letter-spacing: 0.3px;
    font-size: 0.95rem;
    white-space: normal;
    line-height: 1.3;
    }

    /* 高亮关键词 */
    .predictive-search__result--highlight {
    color: {{ section.settings.color_underline }} !important;
    font-weight: 600;
    }

    /* 查看更多按钮 */
    .predictive-search-results button {
    width: 100%;
    height: 36px;
    background: {{ section.settings.color_underline }};
    color: #fff !important;
    border: none;
    border-radius: 8px;
    margin-top: 8px;
    cursor: pointer;
    }

    /* 关闭按钮 */
    .search-close {
    display: none;
    font-size: 2rem;
    align-items: center;
    justify-content: center;
    }

    @media screen and (max-width: 750px) {
    .search-box {
    display: block;
    position: fixed;
    left: 0;
    top: 0;
    padding: 12px 16px;
    width: 100%;
    background: var(--gradient-background);
    z-index: 100;
    transform: translateY(-100%);
    transition: all 0.4s ease;
    }

    .search-box-show {
    transform: translateY(0%);
    }

    .search__form {
    width: 100%;
    }

    .search-input {
    width: 100%;
    font-size: 1rem;
    }

    .search-close {
     display: flex;
    }

    .predictive-search-results {
    position: fixed;
    top: 80px;
    left: 1rem;
    right: 1rem;
    width: auto;
    transform: none;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    }
{% endstyle %}

<div class='search-box'>
{%- if settings.predictive_search_enabled -%}
    <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- else -%}
        <search-form class="search-modal__form">
            {%- endif -%}

            <form action="{{ routes.search_url }}" method="get" class="search__form" role="search">
                <div class="search-field">
                    <input
                            class="search-input"
                            type="search"
                            name="q"
                            value="{{ search.terms | escape }}"
                            placeholder="{{ 'search.content.placeholder' | t }}"
                    >
                    <button class="search-btn">{{ 'search.content.search_button' | t }}</button>
                </div>

                <div class="search-close">
                    {% render 'icon-close' %}
                </div>

                <div id="predictive-search-results-box" class="predictive-search-results hidden">
                    <p class="search_empty hidden">{{ 'search.empty' | t }}</p>
                </div>
            </form>

            {%- if settings.predictive_search_enabled -%}
    </predictive-search>
{%- else -%}
    </search-form>
    {%- endif -%}
</div>
