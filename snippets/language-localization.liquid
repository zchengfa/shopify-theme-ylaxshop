{% style %}
  .language-selector-disclosure {
  position: relative;
  }

  .desktop-language-text {
  display: inline-block !important;
  }
  .mobile-language-text {
  display: none !important;
  }

  @media screen and (max-width: 1024px) {
  .desktop-language-text {
  display: none !important;
  }
  .mobile-language-text {
  display: inline-block !important;
  font-size: 1.2rem;
  font-weight: 500;
  padding: 0 2px;
  }

  .localization-form__select {
  height: 32px !important;
  min-width: 44px !important;
  padding: 0 6px !important;
  border-radius: 6px;
  background: rgba(255,255,255,0.2) !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  }

  .localization-form__select .icon-caret {
  width: 8px;
  height: 8px;
  }

  .disclosure__list-wrapper {
  top: 110% !important;
  right: 0 !important;
  left: auto !important;
  min-width: 140px !important;
  border-radius: 10px !important;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  overflow: hidden;
  }

  .disclosure__link {
  padding: 10px 15px !important;
  font-size: 14px !important;
  }
  }

  @media screen and (max-width: 750px) {
  .localization-form__select {
  height: 28px !important;
  min-width: 40px !important;
  font-size: 13px;
  }
  .disclosure__list-wrapper{
    top: 150% !important;
    left: 0 !important;
    height: fit-content;
    max-height: 6rem;
    width: fit-content;
    transform: translateY(0)
  }
  }
{% endstyle %}
<div class="disclosure language-selector-disclosure">
  <button
    type="button"
    class="disclosure__button localization-form__select localization-selector link link--text caption-large"
    aria-expanded="false"
    aria-controls="{{ localPosition }}List"
    aria-describedby="{{ localPosition }}Label"
  >
    <span class="language-span desktop-language-text">{{ localization.language.endonym_name | capitalize }}</span>
    <span class="mobile-language-text">
      {% if localization.language.iso_code == 'en' %}EN{% elsif localization.language.iso_code == 'zh-CN' %}中{% elsif localization.language.iso_code == 'zh-TW' %}繁{% else %}🌐{% endif %}
    </span>

    {% render 'icon-caret' %}
  </button>

  <div class="disclosure__list-wrapper" hidden>
    <ul id="{{ localPosition }}List" role="list" class="disclosure__list list-unstyled">
      {%- for language in localization.available_languages -%}
        <li class="disclosure__item" tabindex="-1">
          <a
            class="link link--text disclosure__link caption-large focus-inset"
            href="#"
            hreflang="{{ language.iso_code }}"
            lang="{{ language.iso_code }}"
            {% if language.iso_code == localization.language.iso_code %}
              aria-current="true"
            {% endif %}
            data-value="{{ language.iso_code }}"
          >
            <span
              {% if language.iso_code != localization.language.iso_code %}
                class="visibility-hidden"
              {% endif %}
            >
              {%- render 'icon-checkmark' -%}
            </span>
            <span class="language-text">
              {{ language.endonym_name | capitalize }}
            </span>
          </a>
        </li>
      {%- endfor %}
    </ul>
  </div>
</div>

<input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
